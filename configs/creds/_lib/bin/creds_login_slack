#!/usr/bin/env python3
"""Run the Slack OAuth login flow and save the user token."""
from __future__ import annotations

import pathlib
import sys

_HERE = pathlib.Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_HERE))

from creds_lib.cli import login_main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(login_main("slack", sys.argv[1:]))
