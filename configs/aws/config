# AWS Configuration
# Default is aliased to: integ (change to integ|prod as needed)
# To switch default, update the values below to match the desired profile

[default]
# Currently pointing to: dev
region = ap-south-1
output = json

[profile dev]
region = ap-south-1
output = json

[profile integ]
region = ap-south-1
output = json

[profile prod]
region = us-east-1
output = json
