#!/usr/bin/env bash
########################################
# Global pre-commit hook — email identity guard
#
# Verifies that the email Git would attach to this commit matches the org
# the repo belongs to, per the GIT_ORGS env var. Blocks the commit on
# mismatch — most often this means a per-org includeIf in ~/.gitconfig
# silently failed to match (e.g. repo cloned outside any mapped folder
# AND with a remote that doesn't match any mapped org).
#
# GIT_ORGS format: CSV of "<github-org>:<folder>:<email>" triples. First
# entry is the default identity.
#
# This file is managed by mac-setup. Do not edit directly.
# Source: configs/git/hooks/pre-commit
########################################

set -euo pipefail

CURRENT_EMAIL="$(git config user.email 2>/dev/null || echo "")"
GIT_ORGS_RAW="${GIT_ORGS:-}"

# Skip when GIT_ORGS isn't configured — nothing to validate against.
[[ -z "$GIT_ORGS_RAW" ]] && exit 0

REPO_DIR="$(git rev-parse --show-toplevel 2>/dev/null || git rev-parse --git-dir 2>/dev/null || pwd)"
if command -v realpath >/dev/null 2>&1; then
    REPO_DIR="$(realpath "$REPO_DIR" 2>/dev/null || echo "$REPO_DIR")"
fi
REMOTE_URLS="$(git remote -v 2>/dev/null | awk '{print $2}' | sort -u)"

EXPECTED_EMAIL=""
MATCH_REASON=""

# Parse GIT_ORGS into parallel arrays.
declare -a ORG_NAMES ORG_FOLDERS ORG_EMAILS
IFS=',' read -ra _entries <<< "$GIT_ORGS_RAW"
for entry in "${_entries[@]}"; do
    IFS=':' read -r _name _folder _email <<< "$entry"
    _name="$(echo "$_name" | xargs)"
    _folder="$(echo "$_folder" | xargs)"
    _email="$(echo "$_email" | xargs)"
    [[ -z "$_name" || -z "$_folder" || -z "$_email" ]] && continue
    ORG_NAMES+=("$_name")
    ORG_FOLDERS+=("$_folder")
    ORG_EMAILS+=("$_email")
done

[[ ${#ORG_NAMES[@]} -eq 0 ]] && exit 0

# --- 1. Folder-based match (primary) ---
for i in "${!ORG_NAMES[@]}"; do
    folder="${ORG_FOLDERS[$i]}"
    folder_expanded="${folder/#\~/$HOME}"
    if command -v realpath >/dev/null 2>&1; then
        folder_expanded="$(realpath "$folder_expanded" 2>/dev/null || echo "$folder_expanded")"
    fi
    folder_expanded="${folder_expanded%/}"
    if [[ "$REPO_DIR" == "$folder_expanded" || "$REPO_DIR" == "$folder_expanded"/* ]]; then
        EXPECTED_EMAIL="${ORG_EMAILS[$i]}"
        MATCH_REASON="repo path is under '${ORG_FOLDERS[$i]}' (org: ${ORG_NAMES[$i]})"
        break
    fi
done

# --- 2. Remote-URL-based match (fallback) ---
if [[ -z "$EXPECTED_EMAIL" && -n "$REMOTE_URLS" ]]; then
    for i in "${!ORG_NAMES[@]}"; do
        org="${ORG_NAMES[$i]}"
        if echo "$REMOTE_URLS" | grep -qiE "github\.com[:/]${org}/"; then
            EXPECTED_EMAIL="${ORG_EMAILS[$i]}"
            MATCH_REASON="remote matches GitHub org '$org'"
            break
        fi
    done
fi

# --- 3. Default identity (first org) when nothing matched ---
if [[ -z "$EXPECTED_EMAIL" ]]; then
    EXPECTED_EMAIL="${ORG_EMAILS[0]}"
    if [[ -z "$REMOTE_URLS" ]]; then
        MATCH_REASON="repo outside every mapped folder; no remote yet (using first-org default: ${ORG_NAMES[0]})"
    else
        MATCH_REASON="repo outside every mapped folder; no remote matches any mapped org (using first-org default: ${ORG_NAMES[0]})"
    fi
fi

# --- 4. Validate ---
if [[ "$CURRENT_EMAIL" != "$EXPECTED_EMAIL" ]]; then
    echo ""
    echo "ERROR: Git email mismatch — commit blocked"
    echo ""
    echo "  Current email:  $CURRENT_EMAIL"
    echo "  Expected email: $EXPECTED_EMAIL"
    echo "  Reason:         $MATCH_REASON"
    echo ""
    echo "  Fix with:"
    echo "    git config user.email \"$EXPECTED_EMAIL\""
    echo ""
    exit 1
fi
