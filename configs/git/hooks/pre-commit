#!/usr/bin/env bash
########################################
# Global pre-commit hook — email identity guard
#
# Ensures the configured user.email matches what's expected
# based on the remote URL. Blocks commits on mismatch.
#
# This file is managed by mac-setup. Do not edit directly.
# Source: configs/git/hooks/pre-commit
########################################

set -euo pipefail

WORK_EMAIL="${GIT_WORK_EMAIL:-}"
PERSONAL_EMAIL="${GIT_PERSONAL_EMAIL:-}"
CURRENT_EMAIL="$(git config user.email 2>/dev/null || echo "")"

# If env vars aren't set, skip validation
if [[ -z "$WORK_EMAIL" || -z "$PERSONAL_EMAIL" ]]; then
    exit 0
fi

# Resolve the absolute path of this repo's working tree (or git dir for bare repos)
REPO_DIR="$(git rev-parse --show-toplevel 2>/dev/null || git rev-parse --git-dir 2>/dev/null || pwd)"
# Normalize to an absolute, symlink-resolved path for reliable prefix matching
if command -v realpath >/dev/null 2>&1; then
    REPO_DIR="$(realpath "$REPO_DIR" 2>/dev/null || echo "$REPO_DIR")"
fi

# Work folders list (matches the GIT_WORK_FOLDERS used by ~/.gitconfig includeIf).
# Defaults align with roles/git/vars/main.yml: ~/work, ~/workspace
WORK_FOLDERS="${GIT_WORK_FOLDERS:-~/work,~/workspace}"

# Collect all remote URLs
REMOTE_URLS="$(git remote -v 2>/dev/null | awk '{print $2}' | sort -u)"

EXPECTED_EMAIL=""
MATCH_REASON=""
is_work_repo=false

# --- 1. Directory-based detection (primary signal) ---
IFS=',' read -ra work_dirs <<< "$WORK_FOLDERS"
for wd in "${work_dirs[@]}"; do
    wd="$(echo "$wd" | xargs)"  # trim whitespace
    [[ -z "$wd" ]] && continue
    # Expand leading ~ to $HOME
    wd_expanded="${wd/#\~/$HOME}"
    # Resolve symlinks if possible
    if command -v realpath >/dev/null 2>&1; then
        wd_expanded="$(realpath "$wd_expanded" 2>/dev/null || echo "$wd_expanded")"
    fi
    # Strip trailing slash for clean prefix comparison
    wd_expanded="${wd_expanded%/}"
    if [[ "$REPO_DIR" == "$wd_expanded" || "$REPO_DIR" == "$wd_expanded"/* ]]; then
        is_work_repo=true
        MATCH_REASON="repo path is under work folder '$wd'"
        break
    fi
done

# --- 2. Remote URL-based detection (fallback for repos cloned outside work folders) ---
if [[ "$is_work_repo" == false && -n "$REMOTE_URLS" ]]; then
    WORK_GITHUB_ORGS="${GIT_WORK_GITHUB_ORGS:-}"
    WORK_BITBUCKET_ORGS="${GIT_WORK_BITBUCKET_ORGS:-}"

    if [[ -n "$WORK_GITHUB_ORGS" ]]; then
        IFS=',' read -ra gh_orgs <<< "$WORK_GITHUB_ORGS"
        for org in "${gh_orgs[@]}"; do
            org="$(echo "$org" | xargs)"
            [[ -z "$org" ]] && continue
            if echo "$REMOTE_URLS" | grep -qiE "github\.com[:/]${org}/"; then
                is_work_repo=true
                MATCH_REASON="remote matches GitHub org '$org'"
                break
            fi
        done
    fi

    if [[ "$is_work_repo" == false && -n "$WORK_BITBUCKET_ORGS" ]]; then
        IFS=',' read -ra bb_orgs <<< "$WORK_BITBUCKET_ORGS"
        for org in "${bb_orgs[@]}"; do
            org="$(echo "$org" | xargs)"
            [[ -z "$org" ]] && continue
            if echo "$REMOTE_URLS" | grep -qiE "bitbucket\.org[:/]${org}/"; then
                is_work_repo=true
                MATCH_REASON="remote matches Bitbucket workspace '$org'"
                break
            fi
        done
    fi
fi

# --- 3. Decide expected email ---
if [[ "$is_work_repo" == true ]]; then
    EXPECTED_EMAIL="$WORK_EMAIL"
else
    EXPECTED_EMAIL="$PERSONAL_EMAIL"
    if [[ -z "$MATCH_REASON" ]]; then
        if [[ -z "$REMOTE_URLS" ]]; then
            MATCH_REASON="repo path is outside work folders and no remote configured (fresh repo)"
        else
            MATCH_REASON="repo path is outside work folders and remote does not match any work org"
        fi
    fi
fi

# Validate
if [[ "$CURRENT_EMAIL" != "$EXPECTED_EMAIL" ]]; then
    echo ""
    echo "ERROR: Git email mismatch — commit blocked"
    echo ""
    echo "  Current email:  $CURRENT_EMAIL"
    echo "  Expected email: $EXPECTED_EMAIL"
    echo "  Reason:         $MATCH_REASON"
    echo ""
    echo "  Fix with:"
    echo "    git config user.email \"$EXPECTED_EMAIL\""
    echo ""
    exit 1
fi
