# Ghostty Configuration (used by Ghostty and cmux)
# cmux is Ghostty-based and reads this config from ~/.config/ghostty/config
# See: https://ghostty.org/docs/config

font-family = JetBrainsMono Nerd Font
font-size = 15
theme = dark:Atom One Dark,light:Atom One Light
window-padding-x = 4
window-padding-y = 4
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false
