########################################
# ~/.zshenv - Environment variables for mac-setup
#
# Copy this file to ~/.zshenv and fill in your values:
#   cp .zshenv.example ~/.zshenv
#
# This file is sourced by zsh before .zshrc and is used by
# Ansible templates to generate git and SSH configs.
#
# NEVER commit ~/.zshenv — it contains personal data and secrets.
########################################

# --- mise shims (makes mise-managed tools available to GUI apps) ---
export PATH="$HOME/.local/share/mise/shims:$PATH"

########################################
# REQUIRED — Fill these BEFORE running setup
#
# These are used by Ansible templates to generate .gitconfig
# and .ssh/config. Setup will produce broken configs without them.
########################################

# --- Default editor & visual ---
export EDITOR="zed --wait"
export VISUAL="zed --wait"

# --- Git Identity ---
export GIT_USER_NAME="Your Name"
export GIT_PERSONAL_EMAIL="you@example.com"
export GIT_WORK_EMAIL="you@company.com"

# --- SSH Key Filenames (just the filename, not the full path) ---
export SSH_PERSONAL_KEY="id_ed25519_personal"
export SSH_WORK_KEY="id_ed25519_work"

########################################
# RECOMMENDED — Fill these for full work/personal separation
#
# These control which repos get work git config applied.
# Safe to leave defaults initially, but fill in for proper setup.
########################################

# --- Work Folders (comma-separated paths where work repos live) ---
# Git work config (work email, etc.) applies to repos in these directories.
# Defaults to ~/work,~/workspace if not set.
# export GIT_WORK_FOLDERS="~/work,~/workspace"

# --- Git Work Orgs (comma-separated, for remote URL-based config matching) ---
# These ensure work git config applies even for repos cloned outside work folders
export GIT_WORK_GITHUB_ORGS="Quince-Engineering"
export GIT_WORK_BITBUCKET_ORGS="lastbrand"

########################################
# OPTIONAL — Configure later as needed
#
# These are for API tokens, MCP servers, and other integrations.
# They are NOT required for the initial setup to work.
########################################

# --- API Tokens ---
# export ANTHROPIC_API_KEY=""
# export OPENAI_API_KEY=""
# export GEMINI_API_KEY=""

# === GitHub ===
# export GITHUB_PAT=""

