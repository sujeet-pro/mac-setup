########################################
# ~/.zshenv — single source of identity + app home dirs.
#
# This file is symlinked from ~/user-synced-data/mac-setup/zshenv so identity
# travels with the Google Drive sync. Per-machine knobs (machine-specific paths,
# overrides) go in ~/.zshenv.local (sourced first below, never synced).
#
# To apply on a fresh machine:
#   1. Run: bash ~/personal/mac-setup/scripts/migrate-to-synced.sh
#   2. Open a new terminal (loads the symlinked ~/.zshenv).
#   3. Run: cd ~/personal/mac-setup && make update
########################################

# Per-machine overrides (loaded FIRST so they can influence what follows).
[ -r "$HOME/.zshenv.local" ] && . "$HOME/.zshenv.local"

# --- Repo roots --------------------------------------------------------------
export MAC_SETUP_HOME="$HOME/personal/mac-setup"
export ADK_REPO_HOME="$HOME/personal/agents-devkit"

# --- App home dirs (REQUIRED — no fallback in code) -------------------------
export CREDS_HOME="$HOME/user-synced-data/creds"
export ADK_CONFIG_HOME="$HOME/user-synced-data/adk/config"
export ADK_DATA_HOME="$HOME/adk-data"
export ADK_MEMORY_HOME="$HOME/user-synced-data/adk/memory"
export SSH_KEYS_HOME="$HOME/user-synced-data/ssh"

# --- Shell environment -------------------------------------------------------
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"
export EDITOR="zed --wait"
export VISUAL="zed --wait"

# --- Git identity (used by ansible templates) -------------------------------
export GIT_USER_NAME="Your Name"
export GIT_PERSONAL_EMAIL="you@personal.com"       # FILL ME
export GIT_WORK_EMAIL=""                            # FILL ME
export GIT_WORK_GITHUB_ORGS=""                      # FILL ME — comma-separated GitHub work orgs
export GIT_WORK_BITBUCKET_ORGS=""                   # FILL ME — comma-separated Bitbucket work orgs
export SSH_PERSONAL_KEY="id_ed25519"
export SSH_WORK_KEY="id_ed25519"

# --- Claude / agent runtime tweaks -------------------------------------------
# export CLAUDE_CODE_MAX_OUTPUT_TOKENS=32000
# export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --- Per-service creds + non-secret config ----------------------------------
# Loader walks $CREDS_HOME/*/creds.sh and sources each.
. "$MAC_SETUP_HOME/configs/creds/loader.sh"
