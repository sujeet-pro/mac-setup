########################################
# ~/.zshenv.example — canonical template for ~/.zshenv (mac-setup).
#
# Layout (since 2026-05-19):
#   1. ~/.zshenv is minimal — identity + pointer to the creds loader.
#   2. Per-service secrets live in ~/.config/creds/<svc>/creds.sh   (chmod 600).
#   3. Per-service non-secret config in ~/.config/creds/<svc>/config.sh (chmod 644).
#   4. Both are auto-sourced by ~/.config/creds/loader.sh (the line at the bottom).
#   5. Every secret env var is suffixed `_CRED`, so `grep _CRED` lists them all.
#
# Copy this file to ~/.zshenv and fill in your values:
#   cp configs/shell/.zshenv.example ~/.zshenv
#   chmod 600 ~/.zshenv
#
# This file is sourced by zsh before .zshrc and read by Ansible templates
# (roles/git, roles/ssh) when rendering ~/.gitconfig and ~/.ssh/config.
#
# NEVER commit ~/.zshenv or anything under ~/.config/creds/.
########################################

# --- mise shims (makes mise-managed tools available to GUI apps) ---
export PATH="$HOME/.local/share/mise/shims:$PATH"

# --- Default editor ---
export EDITOR="zed --wait"
export VISUAL="zed --wait"

########################################
# REQUIRED — fill BEFORE running `make setup`
########################################

# Display name on every commit.
export GIT_USER_NAME="Your Name"

# Multi-org identity mapping. CSV of `<github-org>:<folder>:<email>` triples.
# The FIRST entry is the default identity (used outside any mapped folder/remote).
# Examples:
#   - "sujeet-pro:~/personal:sujeet@personal.com,Quince-Engineering:~/work:sujeet@quince.com"
export GIT_ORGS="sujeet-pro:~/personal:you@personal.com,YourOrg:~/work:you@work.com"

# Single SSH key for every host. Default: id_ed25519.
export SSH_KEY="id_ed25519"

########################################
# Per-service config + secrets (managed by mac-setup/configs/creds/).
#
# Layout: ~/.config/creds/<svc>/{config.sh,creds.sh}
# The loader walks every service folder and sources config.sh then creds.sh.
# Run `make setup` to scaffold each service's templates the first time.
########################################
[ -r "$HOME/.config/creds/loader.sh" ] && . "$HOME/.config/creds/loader.sh"
