########################################
# ~/.gitconfig — Global Git config
#
# This file is managed by Ansible. Do not edit directly.
# To change, update roles/git/templates/gitconfig.j2 and re-run the playbook.
#
# GIT_ORGS env var maps each GitHub org to a folder + email. The FIRST org
# is the default identity. Per-org overrides live in
# ~/.config/git-configs/<org>.gitconfig.
########################################

{# Parse GIT_ORGS into a list of {name, folder, email}. #}
{% set orgs = [] %}
{% for entry in git_orgs_raw.split(',') %}
{%   set parts = entry.strip().split(':') %}
{%   if parts | length == 3 %}
{%     set _ = orgs.append({"name": parts[0].strip(), "folder": parts[1].strip(), "email": parts[2].strip()}) %}
{%   endif %}
{% endfor %}

########################################
# 1. Base identity (first org wins)
########################################

[user]
    name = {{ git_user_name }}
    email = {{ orgs[0].email }}
    signingkey = ~/.ssh/{{ ssh_key }}.pub

########################################
# 2. Commit signing (SSH)
########################################

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.config/git-configs/allowed_signers

[commit]
    gpgsign = true

[tag]
    gpgsign = true

########################################
# 3. Default branch name for new repos
########################################

[init]
    defaultBranch = main

########################################
# 4. Push / pull behavior (common)
########################################

[push]
    autoSetupRemote = true
    default = current

[pull]
    rebase = false
    ff = only

########################################
# 5. Core behavior (common)
########################################

[core]
    filemode = false
    pager = delta
    hooksPath = ~/.git-hooks

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    hyperlinks = true

[merge]
    ff = only
    conflictstyle = zdiff3

[diff]
    colorMoved = default

########################################
# 6. Colors & pretty output (common)
########################################

[color]
    ui = auto

[log]
    decorate = auto

########################################
# 7. Aliases (common)
########################################

[alias]
    co = checkout
    br = branch
    st = status -sb
    ci = commit
    lg = log --oneline --graph --decorate --all
    ll = log --oneline --decorate --graph --all --date=relative
    dft = "!f() { GIT_EXTERNAL_DIFF=difft git diff \"$@\"; }; f"

########################################
# 8. Per-org conditional includes
#    - gitdir:<folder>/  — match by working tree
#    - hasconfig:remote.*.url:...:<org>/** — match by remote (ssh + https)
########################################
{% for org in orgs %}

# --- {{ org.name }} ({{ org.folder }}) ---
[includeIf "gitdir:{{ org.folder }}/"]
    path = ~/.config/git-configs/{{ org.name }}.gitconfig

[includeIf "hasconfig:remote.*.url:git@github.com:{{ org.name }}/**"]
    path = ~/.config/git-configs/{{ org.name }}.gitconfig

[includeIf "hasconfig:remote.*.url:https://github.com/{{ org.name }}/**"]
    path = ~/.config/git-configs/{{ org.name }}.gitconfig
{% endfor %}

########################################
# End of ~/.gitconfig
########################################
