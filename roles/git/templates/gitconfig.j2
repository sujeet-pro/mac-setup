########################################
# ~/.gitconfig - Global Git config
#
# This file is managed by Ansible. Do not edit directly.
# To change, update roles/git/templates/gitconfig.j2 and re-run the playbook.
#
# Directory conventions:
#   - All personal repos under: ~/personal/
#   - All work repos under configured work folders (GIT_WORK_FOLDERS env var)
#     Defaults to: ~/work/, ~/workspace/
########################################

########################################
# 1. Base identity (common)
########################################

[user]
    name = {{ git_user_name }}
    email = {{ git_personal_email }}

########################################
# 2. Commit signing (SSH)
########################################

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.config/git-configs/allowed_signers

[user]
    signingkey = ~/.ssh/{{ ssh_personal_key }}.pub

[commit]
    gpgsign = true

[tag]
    gpgsign = true

########################################
# 3. Default branch name for new repos
########################################

[init]
    defaultBranch = main

########################################
# 4. Push behavior (common)
########################################

[push]
    autoSetupRemote = true
    default = current

########################################
# 5. Pull behavior (common)
########################################

[pull]
    rebase = false
    ff = only

########################################
# 6. Core behavior (common)
########################################

[core]
    filemode = false
    pager = delta
    hooksPath = ~/.git-hooks

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    hyperlinks = true

[merge]
    ff = only
    conflictstyle = zdiff3

[diff]
    colorMoved = default

########################################
# 7. Colors & pretty output (common)
########################################

[color]
    ui = auto

[log]
    decorate = auto

########################################
# 8. Aliases (common)
########################################

[alias]
    co = checkout
    br = branch
    st = status -sb
    ci = commit
    lg = log --oneline --graph --decorate --all
    ll = log --oneline --decorate --graph --all --date=relative
    dft = "!f() { GIT_EXTERNAL_DIFF=difft git diff \"$@\"; }; f"

########################################
# 9. Conditional includes
#    - Directory-based: for repos under work and personal folders
#    - Remote URL-based: for work repos cloned outside work folders
#
#    Work folders (from GIT_WORK_FOLDERS env var):
{% for folder in git_work_folders.split(',') | map('trim') | select %}
#      {{ folder }}/
{% endfor -%}
########################################

# --- Directory-based includes (work) ---
{% for folder in git_work_folders.split(',') | map('trim') | select %}

[includeIf "gitdir:{{ folder }}/"]
    path = ~/.config/git-configs/work.gitconfig
{% endfor %}

# --- Remote URL-based includes (GitHub orgs) ---
{% for org in git_work_github_orgs.split(',') | map('trim') | select %}

[includeIf "hasconfig:remote.*.url:git@github.com:{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig

[includeIf "hasconfig:remote.*.url:https://github.com/{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig
{% endfor %}

# --- Remote URL-based includes (Bitbucket orgs) ---
{% for org in git_work_bitbucket_orgs.split(',') | map('trim') | select %}

[includeIf "hasconfig:remote.*.url:git@bitbucket.org:{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig

[includeIf "hasconfig:remote.*.url:https://bitbucket.org/{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig
{% endfor %}

########################################
# End of ~/.gitconfig
########################################
