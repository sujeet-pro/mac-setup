########################################
# ~/.config/git-configs/work.gitconfig - Work-specific Git config
#
# This file is managed by Ansible. Do not edit directly.
# To change, update roles/git/templates/gitconfig-work.j2 and re-run the playbook.
########################################

[user]
    name = {{ git_user_name }}
    email = {{ git_work_email }}
    signingkey = ~/.ssh/{{ ssh_work_key }}.pub

[core]
    excludesFile = ~/.gitignore-work

[init]
    defaultBranch = master

[pull]
    rebase = true

########################################
# End of ~/.gitconfig-work
########################################
